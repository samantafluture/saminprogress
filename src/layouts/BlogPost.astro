---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  updatedDate?: Date;
  heroImage?: string;
  heroImageAlt?: string;
}

const { title, description, date, tags = [], updatedDate, heroImage, heroImageAlt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="blog-post">
    <nav class="breadcrumbs">
      <a href="/" class="breadcrumb-link">home</a>
      <span class="breadcrumb-sep" aria-hidden="true">/</span>
      <a href="/blog" class="breadcrumb-link">writing</a>
      <span class="breadcrumb-sep" aria-hidden="true">/</span>
      <span class="breadcrumb-current">{title}</span>
    </nav>
    <header class="post-header">
      {heroImage && <img src={heroImage} alt={heroImageAlt || ""} />}
      <div class="post-meta">
        <span class="meta-prefix" aria-hidden="true"># </span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {updatedDate && (
          <span>
            &middot; updated <time datetime={updatedDate.toISOString()}>
              {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </span>
        )}
      </div>
      <h1 class="post-title">
        <span class="title-prefix" aria-hidden="true">&gt; </span>{title}
      </h1>
    </header>
    <div class="post-content">
      <slot />
    </div>
    {tags.length > 0 && (
      <footer class="post-footer">
        <div class="post-tags">
          {tags.map((tag) => <a href={`/blog/tag/${tag}/`} class="tag">#{tag}</a>)}
        </div>
      </footer>
    )}
    <div class="back-link">
      <a href="/blog"><span aria-hidden="true">&larr; </span>back to writing</a>
    </div>
  </article>
</BaseLayout>

<style>
  /* Breadcrumbs */
  .breadcrumbs {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
    margin-bottom: 1.5rem;
  }

  .breadcrumb-link {
    color: var(--cyan);
    text-decoration: none;
    cursor: pointer;
  }

  .breadcrumb-link:hover {
    color: var(--blue);
  }

  .breadcrumb-sep {
    color: var(--fg-faint);
    margin: 0 4px;
  }

  .breadcrumb-current {
    color: var(--fg);
  }

  /* Header */
  .post-header {
    margin-bottom: 2rem;
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
    margin-bottom: 6px;
  }

  .meta-prefix {
    color: var(--cyan);
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    color: var(--fg-strong);
    line-height: 1.35;
    margin-bottom: 8px;
  }

  .title-prefix {
    color: var(--yellow);
  }

  /* Article body content */
  .post-content {
    font-family: var(--font-serif);
    font-size: 17px;
    color: var(--fg);
    line-height: 1.65;
  }

  @media (min-width: 768px) {
    .post-title {
      font-size: 28px;
    }
  }

  /* Hide duplicate h1 from markdown — the post title is already in .post-title */
  .post-content :global(h1) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .post-content :global(h2) {
    font-family: var(--font-mono);
    font-size: 17px;
    font-weight: 500;
    color: var(--fg-strong);
    margin: 2rem 0 0.75rem;
  }

  .post-content :global(h3) {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    color: var(--fg-strong);
    margin: 1.5rem 0 0.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1rem;
  }

  .post-content :global(a) {
    color: var(--blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    color: var(--cyan);
  }

  .post-content :global(blockquote) {
    border-left: 2px solid var(--border);
    padding-left: 12px;
    color: var(--fg-muted);
    font-style: italic;
    margin: 1rem 0;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 14px;
    background: var(--border);
    padding: 2px 5px;
  }

  .post-content :global(pre) {
    background: var(--bg-header);
    color: var(--bg);
    padding: 1rem;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .post-content :global(ul) {
    list-style: disc;
  }

  .post-content :global(ol) {
    list-style: decimal;
  }

  .post-content :global(li) {
    margin-bottom: 0.25rem;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .post-content :global(img) {
    margin: 1rem 0;
  }

  /* Post footer with tags */
  .post-footer {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .tag {
    font-family: var(--font-serif);
    font-size: 12px;
    font-style: italic;
    font-weight: 600;
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }

  .tag:hover {
    color: var(--fg-strong);
  }

  /* Back link */
  .back-link {
    margin-top: 2rem;
    padding-top: 1rem;
  }

  .back-link a {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--cyan);
    text-decoration: none;
  }

  .back-link a:hover {
    color: var(--blue);
  }
</style>
