---
interface Props {
  name: string;
  oneLiner: string;
  url?: string;
  repo?: string;
  stack: string[];
  ai: string;
  highlights: string[];
  status: string;
}

const { name, oneLiner, url, repo, stack, ai, highlights, status } = Astro.props;
---

<article class="project-card">
  <div class="project-meta">
    <span class="meta-prefix" aria-hidden="true"># </span>
    <span class="status-badge">{status}</span>
  </div>
  <h3 class="project-title">
    <span class="title-prefix" aria-hidden="true">&gt; </span>{name}
  </h3>
  <p class="project-oneliner">{oneLiner}</p>
  <div class="project-stack">
    {stack.map((tech) => (
      <span class="stack-badge">{tech}</span>
    ))}
  </div>
  <p class="project-ai">
    <span class="ai-label" aria-hidden="true">AI: </span>{ai}
  </p>
  <ul class="project-highlights">
    {highlights.map((item) => (
      <li>
        <span class="highlight-prefix" aria-hidden="true">- </span>{item}
      </li>
    ))}
  </ul>
  <div class="project-links">
    {url && (
      <a href={url} class="link-live" target="_blank" rel="noopener noreferrer">
        <span aria-hidden="true">&rarr; </span>live
      </a>
    )}
    {repo && (
      <a href={repo} class="link-source" target="_blank" rel="noopener noreferrer">
        <span aria-hidden="true">&rarr; </span>source
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    padding-bottom: 1.75rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
  }

  .project-card:last-child {
    border-bottom: none;
  }

  .project-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
    margin-bottom: 4px;
  }

  .meta-prefix {
    color: var(--cyan);
  }

  .status-badge {
    color: var(--cyan);
    font-weight: 500;
  }

  .project-title {
    font-family: var(--font-mono);
    font-size: 19px;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 6px;
    color: var(--fg-strong);
  }

  .title-prefix {
    color: var(--yellow);
  }

  .project-oneliner {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--fg);
    line-height: 1.55;
    border-left: 2px solid var(--border);
    padding-left: 12px;
    margin-bottom: 12px;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 10px;
  }

  .stack-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    background: var(--bg-alt);
    color: var(--fg-muted);
    padding: 2px 8px;
  }

  .project-ai {
    font-family: var(--font-serif);
    font-size: 14px;
    font-style: italic;
    color: var(--cyan);
    margin-bottom: 10px;
  }

  .ai-label {
    font-family: var(--font-mono);
    font-style: normal;
    font-weight: 500;
  }

  .project-highlights {
    margin-bottom: 14px;
  }

  .project-highlights li {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--fg);
    line-height: 1.6;
  }

  .highlight-prefix {
    font-family: var(--font-mono);
    color: var(--green);
    font-weight: 700;
  }

  .project-links {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .link-live {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    background: var(--yellow);
    color: var(--base03);
    padding: 5px 16px;
    text-decoration: none;
  }

  .link-live:hover {
    background: var(--blue);
    color: var(--bg);
  }

  .link-source {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--cyan);
    text-decoration: none;
  }

  .link-source:hover {
    color: var(--blue);
  }
</style>
