---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/blog') {
    return currentPath === '/blog' || currentPath === '/blog/' || currentPath.startsWith('/blog/');
  }
  return currentPath === href || currentPath === href + '/';
}

const navLinks = [
  { href: '/blog', label: 'writing' },
];
---

<header class="site-header">
  <div class="prompt-bar">
    <div class="prompt-bar-inner">
      <span class="segment segment-user">sam@progress</span>
      <span class="segment segment-branch">&#x1F680; dev</span>
      <span class="segment segment-command">cat ~/thoughts/all.md | grep -v overthinking | sort -r</span>
      <span class="segment segment-location">&#x1F4CC; montreal</span>
    </div>
  </div>
  <div class="header-content">
    <div class="site-name-row-wrapper">
      <a href="/" class="site-name-link">
        <div class="site-name-row">
          <span class="prompt-symbol">~$</span>
          <span class="site-name">saminprogress</span>
          <span class="cursor" aria-hidden="true"></span>
        </div>
      </a>
      <ThemeToggle />
    </div>
    <div class="tagline">
      // personal journal &middot; lead dev life &middot; things i'm building
    </div>
    <nav class="main-nav">
      {navLinks.map((link) => (
        <a href={link.href} class:list={['nav-link', { active: isActive(link.href) }]}>
          <span class="nav-prefix">./</span>{link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--bg-header);
  }

  /* Prompt bar — full width background, centered content */
  .prompt-bar {
    background: var(--fg-strong);
  }

  .prompt-bar-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    overflow-x: auto;
  }

  .segment {
    padding: 10px 16px;
    white-space: nowrap;
  }

  .segment-user {
    background: var(--green);
    color: var(--base03);
  }

  .segment-branch {
    background: var(--yellow);
    color: var(--base03);
  }

  .segment-command {
    background: var(--fg-strong);
    color: var(--bg);
    font-style: italic;
    font-weight: 400;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .segment-location {
    background: var(--blue);
    color: var(--bg);
    margin-left: auto;
  }

  /* Header content — centered */
  .header-content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Site name row with toggle */
  .site-name-row-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-name-link {
    display: block;
    cursor: pointer;
    text-decoration: none;
  }

  .site-name-row {
    padding: 14px 0 6px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .prompt-symbol {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--cyan);
  }

  .site-name {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 500;
    color: var(--base3);
  }

  .cursor {
    display: inline-block;
    width: 10px;
    height: 18px;
    background: var(--yellow);
    animation: blink 1s step-end infinite;
  }

  /* Tagline */
  .tagline {
    font-family: var(--font-serif);
    font-size: 13px;
    font-style: italic;
    color: var(--fg-muted);
    padding: 0 0 8px;
  }

  /* Navigation */
  .main-nav {
    padding: 8px 0 12px;
    display: flex;
    gap: 0;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    padding: 4px 14px;
    background: var(--fg-strong);
    color: var(--bg);
    border: none;
    border-radius: 0;
    text-decoration: none;
    display: inline-block;
  }

  .nav-link:hover {
    background: var(--blue);
  }

  .nav-link.active {
    background: var(--yellow);
    color: var(--base03);
  }

  .nav-link.active .nav-prefix {
    color: var(--base03);
  }

  .nav-prefix {
    color: var(--cyan);
  }
</style>
