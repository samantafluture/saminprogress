---
interface Props {
  title: string;
  date: Date;
  description: string;
  tags?: string[];
  slug: string;
  substack?: string;
}

const { title, date, description, tags = [], slug, substack } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const titleHref = substack || `/blog/${slug}/`;
const titleTarget = substack ? '_blank' : undefined;
const titleRel = substack ? 'noopener noreferrer' : undefined;
---

<article class="post-item">
  <div class="post-meta">
    <span class="meta-prefix" aria-hidden="true"># </span>
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <h3 class="post-title">
    <a href={titleHref} target={titleTarget} rel={titleRel}>
      <span class="title-prefix" aria-hidden="true">&gt; </span>{title}
    </a>
    {substack && <span class="lock-badge">[substack]</span>}
  </h3>
  {tags.length > 0 && (
    <div class="post-tags">
      {tags.map((tag) => (
        <a href={`/blog/tag/${tag}/`} class="tag">#{tag}</a>
      ))}
    </div>
  )}
  {description && (
    <p class="post-excerpt">{description}</p>
  )}
  {substack ? (
    <a href={substack} class="read-more read-more--substack" target="_blank" rel="noopener noreferrer" aria-label={`read on substack: ${title}`}>
      <span aria-hidden="true">&rarr; </span>read on substack
    </a>
  ) : (
    <a href={`/blog/${slug}/`} class="read-more" aria-label={`read more: ${title}`}>
      <span aria-hidden="true">&rarr; </span>read more
    </a>
  )}
</article>

<style>
  .post-item {
    padding-bottom: 1.75rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
    margin-bottom: 4px;
  }

  .meta-prefix {
    color: var(--cyan);
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 19px;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 6px;
  }

  .post-title a {
    color: var(--fg-strong);
    text-decoration: none;
    word-spacing: normal;
  }

  .post-title a:hover {
    color: var(--blue);
  }

  .title-prefix {
    color: var(--yellow);
  }

  .lock-badge {
    font-size: 11px;
    font-weight: 500;
    color: var(--orange);
    margin-left: 8px;
    vertical-align: middle;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 10px;
  }

  .tag {
    font-family: var(--font-serif);
    font-size: 12px;
    font-style: italic;
    font-weight: 600;
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }

  .tag:hover {
    color: var(--fg-strong);
  }

  .post-excerpt {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--fg);
    line-height: 1.55;
    border-left: 2px solid var(--border);
    padding-left: 12px;
    margin-bottom: 14px;
  }

  .read-more {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    background: var(--yellow);
    color: var(--base03);
    padding: 5px 16px;
    border: none;
    border-radius: 0;
    text-decoration: none;
  }

  .read-more:hover {
    background: var(--blue);
    color: var(--bg);
  }

  .read-more--substack {
    background: var(--orange);
    color: var(--bg);
  }

  .read-more--substack:hover {
    background: var(--blue);
    color: var(--bg);
  }
</style>
