---
interface Props {
  title: string;
  date: Date;
  description: string;
  tags?: string[];
  slug: string;
}

const { title, date, description, tags = [], slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="post-item">
  <div class="post-meta">
    <span class="meta-prefix"># </span>
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <h3 class="post-title">
    <a href={`/blog/${slug}/`}>
      <span class="title-prefix">&gt; </span>{title}
    </a>
  </h3>
  {tags.length > 0 && (
    <div class="post-tags">
      {tags.map((tag) => (
        <span class="tag">#{tag}</span>
      ))}
    </div>
  )}
  {description && (
    <p class="post-excerpt">{description}</p>
  )}
  <a href={`/blog/${slug}/`} class="read-more">&rarr; read more</a>
</article>

<style>
  .post-item {
    padding-bottom: 1.75rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--base2);
  }

  .post-item:last-child {
    border-bottom: none;
  }

  /* Meta line */
  .post-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--base1);
    margin-bottom: 4px;
  }

  .meta-prefix {
    color: var(--cyan);
  }

  /* Title */
  .post-title {
    font-family: var(--font-mono);
    font-size: 19px;
    font-weight: 500;
    line-height: 1.25;
    margin-bottom: 6px;
  }

  .post-title a {
    color: var(--base01);
    text-decoration: none;
  }

  .post-title a:hover {
    color: var(--blue);
  }

  .title-prefix {
    color: var(--yellow);
  }

  /* Tags */
  .post-tags {
    display: flex;
    gap: 12px;
    margin-bottom: 10px;
  }

  .tag {
    font-family: var(--font-serif);
    font-size: 12px;
    font-style: italic;
    font-weight: 600;
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: default;
  }

  .tag:hover {
    color: var(--base01);
  }

  /* Excerpt */
  .post-excerpt {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--base00);
    line-height: 1.55;
    border-left: 2px solid var(--base2);
    padding-left: 12px;
    margin-bottom: 14px;
  }

  /* Read more */
  .read-more {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    background: var(--yellow);
    color: var(--base03);
    padding: 5px 16px;
    border: none;
    border-radius: 0;
    text-decoration: none;
  }

  .read-more:hover {
    background: var(--blue);
    color: var(--base3);
  }
</style>
