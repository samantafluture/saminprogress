---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="saminprogress">
  <div class="section-label">
    <span class="label-prefix">$ cat </span><span class="label-path">~/README.md</span>
  </div>

  <article class="home">
    <!-- hero -->
    <header class="home-header">
      <h1 class="home-title">
        <span class="title-prefix" aria-hidden="true">&gt; </span>samanta fluture
      </h1>
      <div class="home-meta">
        <span class="meta-prefix" aria-hidden="true"># </span>lead dev &middot; media artist &middot; montreal
      </div>
    </header>

    <!-- about blurb -->
    <section class="home-section">
      <h2 class="section-heading">
        <span class="heading-prefix" aria-hidden="true">## </span>whoami
      </h2>
      <div class="home-prose">
        <p>
          I'm a front-end lead by day and an AI-workflow junkie by night.
          I lead a team building React &amp; TypeScript UIs, and after hours I'm deep in
          side projects where AI does the heavy lifting. Claude Code skills, Gemini pipelines,
          a self-hosted agent platform on a $10 VPS.
          This is my corner of the internet. A journal about dev life,
          the things I'm building, and whatever else is on my mind.
        </p>
      </div>
    </section>

    <!-- subscribe -->
    <section class="home-section">
      <h2 class="section-heading">
        <span class="heading-prefix" aria-hidden="true">## </span>subscribe
      </h2>
      <div class="home-prose">
        <p>
          Some posts live exclusively on Substack. If you want the full picture,
          dev stories, deep dives, and the stuff I only share with subscribers,
          that's where to find it.
        </p>
      </div>
      <a href="https://samantafluture.substack.com/" class="subscribe-cta" target="_blank" rel="noopener noreferrer">
        <span aria-hidden="true">&rarr; </span>subscribe on substack<span class="sr-only"> (opens in new tab)</span>
      </a>
    </section>

  </article>
</BaseLayout>

<style>
  /* Section label — terminal command */
  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    margin-bottom: 1.25rem;
  }

  .label-prefix {
    color: var(--green);
  }

  .label-path {
    color: var(--fg-faint);
  }

  /* Home header */
  .home-header {
    margin-bottom: 2rem;
  }

  .home-title {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    color: var(--fg-strong);
    line-height: 1.35;
    margin-bottom: 6px;
  }

  .title-prefix {
    color: var(--yellow);
  }

  .home-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
  }

  .meta-prefix {
    color: var(--cyan);
  }

  @media (min-width: 768px) {
    .home-title {
      font-size: 28px;
    }
  }

  /* Sections */
  .home-section {
    margin-bottom: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    color: var(--fg-strong);
    margin-bottom: 1.25rem;
  }

  .heading-prefix {
    color: var(--cyan);
  }

  /* Prose */
  .home-prose {
    font-family: var(--font-serif);
    font-size: 17px;
    color: var(--fg);
    line-height: 1.65;
  }

  .home-prose p {
    margin-bottom: 1rem;
  }

  /* Subscribe CTA */
  .subscribe-cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    background: var(--orange);
    color: var(--bg);
    padding: 5px 16px;
    border: none;
    border-radius: 0;
    text-decoration: none;
    margin-top: 1rem;
  }

  .subscribe-cta:hover {
    background: var(--blue);
    color: var(--bg);
  }

</style>
