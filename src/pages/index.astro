---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="saminprogress">
  <div class="section-label">
    <span class="label-prefix">$ cat </span><span class="label-path">~/README.md</span>
  </div>

  <article class="home">
    <!-- hero -->
    <header class="home-header">
      <h1 class="home-title">
        <span class="title-prefix" aria-hidden="true">&gt; </span>samanta fluture
      </h1>
      <div class="home-meta">
        <span class="meta-prefix" aria-hidden="true"># </span>lead dev &middot; media artist &middot; montreal
      </div>
    </header>

    <!-- about blurb -->
    <section class="home-section">
      <h2 class="section-heading">
        <span class="heading-prefix" aria-hidden="true">## </span>whoami
      </h2>
      <div class="home-prose">
        <p>
          I'm a front-end lead by day and an AI-workflow junkie by night.
          I lead a team building React &amp; TypeScript UIs, and after hours I'm deep in
          side projects where AI does the heavy lifting. Claude Code skills, Gemini pipelines,
          a self-hosted agent platform on a $10 VPS.
          This is my corner of the internet. A journal about dev life,
          the things I'm building, and whatever else is on my mind.
        </p>
      </div>
    </section>

    <!-- site sections -->
    <section class="home-section">
      <h2 class="section-heading">
        <span class="heading-prefix" aria-hidden="true">## </span>ls ./
      </h2>
      <div class="nav-list">
        <a href="/blog" class="nav-item">
          <span class="nav-name">
            <span class="nav-prefix" aria-hidden="true">&rarr;</span> ./writing
          </span>
          <span class="nav-desc">personal journal about lead dev life</span>
        </a>
        <a href="/projects" class="nav-item">
          <span class="nav-name">
            <span class="nav-prefix" aria-hidden="true">&rarr;</span> ./projects
          </span>
          <span class="nav-desc">things I'm building with AI</span>
        </a>
        <a href="/about" class="nav-item">
          <span class="nav-name">
            <span class="nav-prefix" aria-hidden="true">&rarr;</span> ./about
          </span>
          <span class="nav-desc">full CV, skills, experience</span>
        </a>
      </div>
    </section>

    <!-- links -->
    <section class="home-section">
      <h2 class="section-heading">
        <span class="heading-prefix" aria-hidden="true">## </span>links
      </h2>
      <div class="links-list">
        <a href="https://github.com/samantafluture/" class="home-link" target="_blank" rel="noopener noreferrer">
          <span class="link-arrow" aria-hidden="true">&rarr;</span> github.com/samantafluture<span class="sr-only"> (opens in new tab)</span>
        </a>
        <a href="https://linkedin.com/in/samantafluture/" class="home-link" target="_blank" rel="noopener noreferrer">
          <span class="link-arrow" aria-hidden="true">&rarr;</span> linkedin.com/in/samantafluture<span class="sr-only"> (opens in new tab)</span>
        </a>
        <a href="mailto:samantafluture@gmail.com" class="home-link">
          <span class="link-arrow" aria-hidden="true">&rarr;</span> samantafluture@gmail.com
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* Section label — terminal command */
  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    margin-bottom: 1.25rem;
  }

  .label-prefix {
    color: var(--green);
  }

  .label-path {
    color: var(--fg-faint);
  }

  /* Home header */
  .home-header {
    margin-bottom: 2rem;
  }

  .home-title {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    color: var(--fg-strong);
    line-height: 1.35;
    margin-bottom: 6px;
  }

  .title-prefix {
    color: var(--yellow);
  }

  .home-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
  }

  .meta-prefix {
    color: var(--cyan);
  }

  @media (min-width: 768px) {
    .home-title {
      font-size: 28px;
    }
  }

  /* Sections */
  .home-section {
    margin-bottom: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    color: var(--fg-strong);
    margin-bottom: 1.25rem;
  }

  .heading-prefix {
    color: var(--cyan);
  }

  /* Prose */
  .home-prose {
    font-family: var(--font-serif);
    font-size: 17px;
    color: var(--fg);
    line-height: 1.65;
  }

  .home-prose p {
    margin-bottom: 1rem;
  }

  /* Site navigation links */
  .nav-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .nav-item {
    display: block;
    padding-left: 1rem;
    border-left: 2px solid var(--border);
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .nav-item:hover {
    border-left-color: var(--yellow);
  }

  .nav-name {
    display: block;
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 700;
    color: var(--fg-strong);
    margin-bottom: 4px;
  }

  .nav-prefix {
    color: var(--yellow);
    margin-right: 4px;
  }

  .nav-item:hover .nav-name {
    color: var(--cyan);
  }

  .nav-desc {
    display: block;
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--fg);
    line-height: 1.55;
  }

  /* Links */
  .links-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .home-link {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .home-link:hover {
    color: var(--cyan);
  }

  .link-arrow {
    color: var(--yellow);
    text-decoration: none;
    margin-right: 4px;
  }

  /* Visually hidden but accessible to screen readers */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
